# ─────────────────────────────────────────────────────────────────────────────
# VEXI environment variables
# Copy this file to .env.local and fill in real values.
# .env.local is git-ignored and never committed.
# ─────────────────────────────────────────────────────────────────────────────

# Postmark — contact form email delivery
# All three variables must be set to enable Postmark.
# When any is absent the API falls back to console.log (dev / staging safe).
POSTMARK_API_TOKEN=your-postmark-server-api-token
CONTACT_EMAIL_TO=inbox@yourdomain.com
CONTACT_EMAIL_FROM=noreply@yourdomain.com

# ── EventFlow External Contacts (optional)
# Set both to forward contact submissions to EventFlow.
# If either is missing, forwarding is silently skipped.
EVENTFLOW_EXTERNAL_CONTACTS_URL=https://event-flow.co.uk/api/integrations/external-contacts
EVENTFLOW_EXTERNAL_CONTACTS_SECRET=your-shared-secret-here
